FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=cambia-esta-clave-secreta-en-produccion-2025

# ── PostgreSQL ──────────────────────────────────────────
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db
# Ejemplos por plataforma:
#   Local:      postgresql://postgres:mipassword@localhost:5432/liga_db
#   Supabase:   postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
#   Railway:    (usa la variable DATABASE_URL que ellos entregan)
#   Render:     (usa la variable DATABASE_URL que ellos entregan)
DATABASE_URL=postgresql://postgres:1234.@localhost:5432/liga_db

MAX_CONTENT_LENGTH=5242880
UPLOAD_FOLDER=app/static/img/uploads
